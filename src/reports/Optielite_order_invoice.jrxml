		<element kind="staticText" uuid="78d20473-9a4f-40fc-940f-c1f0ac3c8fee" x="4" y="60" width="10" height="15" fontSize="11.0" hTextAlign="Center" vTextAlign="Top">
			<text><![CDATA[•]]></text>
