		<element kind="staticText" uuid="7bc4b6e5-d13d-4205-b49c-9bc15d33c87d" x="1" y="0" width="150" height="14" fontSize="11.0" bold="true">
			<text><![CDATA[You were served by:]]></text>
		</element>
		<element kind="staticText" uuid="b507c772-2ffc-4ef8-bd6c-e9df60e61804" x="15" y="14" width="350" height="10" fontSize="6.0" hTextAlign="Left" vTextAlign="Middle">
			<text><![CDATA[Please collect your spectacle within 90 days, otherwise, the order will be cancelled.]]></text>
		</element>
		<element kind="staticText" uuid="6ed65870-0d08-4051-b41e-a50c1e9efb05" x="15" y="24" width="350" height="10" fontSize="6.0" bold="true">
			<text><![CDATA[Spectacles will be released after settling the full amount]]></text>
		</element>
		<element kind="staticText" uuid="6f82c443-58cc-46f6-86f9-a1dc2bd68019" x="15" y="34" width="350" height="10" fontSize="6.0">
			<text><![CDATA[Repair & adjustments of frames at customers' risk.]]></text>
		</element>
