		<element kind="staticText" uuid="f0cf77c1-b241-44a6-8163-be9232990c44" x="15" y="44" width="350" height="10" fontSize="6.0">
			<text><![CDATA[Once booked, orders cannot be cancelled]]></text>
		</element>
		<element kind="staticText" uuid="e323c14b-f650-4956-9c37-2abf41173e02" x="15" y="54" width="350" height="10" fontSize="6.0">
			<text><![CDATA[If this invoice is fully paid, it should be treated as a receipt of full payment]]></text>
		</element>
		<element kind="staticText" uuid="58170a07-74c2-4eb1-b429-0a57cae32f43" x="15" y="64" width="350" height="10" fontSize="6.0">
			<text><![CDATA[ If any advance is paid for this invoice this should be treated as a Receipt of advance.]]></text>
		</element>
		<element kind="staticText" uuid="0927db12-647c-4b40-b426-01240289379e" x="4" y="40" width="10" height="15" fontSize="11.0" hTextAlign="Center" vTextAlign="Top">
