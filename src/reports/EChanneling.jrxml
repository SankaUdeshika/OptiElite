	<parameter name="appoinmentId" class="java.lang.String"/>
	<query language="sql"><![CDATA[SELECT 
`appoinment_id`,
`ref_no`,
`date`,
`time`,
`total`,
`doctor_fee`,
`channeling_fee`,
`Doctor_doc_id`,
`customer_mobile`,
`users_id`,
`payment_status_id`,
`customer`.`mobile`,
`filenumber`,
`register_date`,
`channeling_appoinment`.`location_id`,
`address_line1`,
`address_line2`,
`telephone_land`,
`nic`,
`birthday`,
`name`,
`remark`,
`doc_id`,
`doc_name`,
`address`,
`specialization`
FROM channeling_appoinment
	INNER JOIN customer ON 
	 customer.mobile = channeling_appoinment.customer_mobile 
	INNER JOIN doctor ON 
	 doctor.doc_id = channeling_appoinment.`Doctor_doc_id`
	 WHERE `appoinment_id`  =$P{appoinmentId} ]]></query>
