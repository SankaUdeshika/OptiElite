	<parameter name="id" class="java.lang.String"/>
	<parameter name="payment1" class="java.lang.String"/>
	<parameter name="payment2" class="java.lang.String"/>
	<parameter name="payment3" class="java.lang.String"/>
	<parameter name="payment4" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT
	`web`,
	`reg_no`,
	`company_email`,
	`order_time`,
	`reg_name`,
	`location_mobile2`,
	`product_id`,
	`bag`,
	`box`,
	`clothing`,
	`payment_amount`,
	 `advance_payment`,
	`branch_address`,
	`locaiton_mobile`,
	`branch_name`,
	`payment_name`,
	`saling_price`,
	`location_name`,
	invoice_item.qty,
	`Category`,
	`sub_category`,
	`brand_name`,
	`product_name`,
	invoice.invoice_id,
	`date`,
	`total_price`,
	`discount`,
	`subtotal`,
	`address_line1`,
	`address_line2`,
	customer.mobile,
	`mobile2`,
	`telephone_land`,
	`nic`,
	`name`
FROM invoice
	INNER JOIN customer ON 
	 customer.mobile = invoice.customer_mobile 
	INNER JOIN invoice_item ON 
	 invoice_item.invoice_id = invoice.invoice_id 
	INNER JOIN stock ON 
	 stock.id = invoice_item.stock_id 
	INNER JOIN product ON 
	 product.id = stock.product_id 
	INNER JOIN brand ON 
	 brand.id = product.brand_id 
	INNER JOIN sub_category ON 
	 sub_category.id = product.sub_category_id 
	INNER JOIN category ON 
	 category.id = sub_category.category_id 
	INNER JOIN location ON 
	 location.id = invoice_location
	INNER JOIN payment_method ON 
	 payment_method.`Payment_id` = invoice.`payment_method_Payment_id` 
WHERE 
	 invoice.invoice_id = $P{id}]]></query>
