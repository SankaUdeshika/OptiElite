	<parameter name="id" class="java.lang.String"/>
	<parameter name="payment1" class="java.lang.String"/>
	<parameter name="payment2" class="java.lang.String"/>
	<parameter name="payment3" class="java.lang.String"/>
	<parameter name="payment4" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT 
	`extra_charges`.`description` AS charge_description,
	`amount`,
	`7_days__lens_warrenty`,
	`order_time`,
	`discount_percentage`,
	`branch_address`,
	`company_email`,
	`web`,
	`reg_no`,
	`reg_name`,
	`lens_id`, 
	`bag`,
	`box`,
	`clothing`,
	`payment_amount`,
	`lens_Qty`,
	`lens_price`,
	`lens_code`,
	`location_mobile2`,
	`lenstotal`,
	`advance_payment`,
	`prescription_details_job_no`,
	`branch_address`,
	`locaiton_mobile`,
	`branch_name`,
	`payment_name`,
	`location_name`,
	invoice.invoice_id,
	`date`,
	`total_price`,
	`discount`,
	`subtotal`,
	`address_line1`,
	`address_line2`,
	customer.mobile,
	`mobile2`,
	`telephone_land`,
	`nic`,
	`name`
FROM invoice
	INNER JOIN customer ON 
	 customer.mobile = invoice.customer_mobile 
	INNER JOIN location ON 
	 location.id = invoice_location
	INNER JOIN payment_method ON 
	 payment_method.`Payment_id` = invoice.`payment_method_Payment_id` 
	LEFT JOIN lens_stock ON 
	 invoice.lens_stock_lens_id = lens_stock.lens_id 
	 LEFT JOIN extra_charges ON
	 extra_charges.invoice_invoice_id = invoice.invoice_id
WHERE 
	 invoice.invoice_id = $P{id}]]></query>
