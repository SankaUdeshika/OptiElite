	<parameter name="repairId" class="java.lang.String"/>
	<parameter name="stock_id" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT repair.date,
	repair.invoice_invoice_id,
	repair.customer_mobile,
	repair.`payment_method_Payment_id`,
	`pre_existing_damage`,
	`problem_description`,
	`approx_cost`,
	`total_cost`,
	`name`,
	`lens_stock_lens_id`,
	`payment_name`
FROM repair
	INNER JOIN customer ON 
	 customer.mobile = repair.customer_mobile 
	INNER JOIN invoice ON 
	 invoice.invoice_id = repair.invoice_invoice_id 
	INNER JOIN payment_method ON 
	 payment_method.`Payment_id` = repair.`payment_method_Payment_id` 
WHERE 
	 repair_id = $P{repairId}]]></query>
