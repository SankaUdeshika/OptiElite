	<parameter name="id" class="java.lang.String"/>
	<parameter name="tintName" class="java.lang.String"/>
	<parameter name="coatingName" class="java.lang.String"/>
	<parameter name="DesignName" class="java.lang.String"/>
	<parameter name="lensTypeName" class="java.lang.String"/>
	<parameter name="lens_brandName" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT `warrenty`,`product`.`id`,`lenstotal`,`advance_payment`,`prescription_details_job_no`,`branch_address`,`locaiton_mobile`,`branch_name`,`payment_name`,`saling_price`,`location_name`,`invoice_item`.`qty`,`Category`,`sub_category`,`brand_name`,`product_name`,`invoice`.`invoice_id`,`date`,`total_price`,`discount`,`subtotal`,`address_line1`,`address_line2`,`mobile`,`mobile2`,`telephone_land`,`nic`,`name` FROM `invoice`
INNER JOIN `customer` ON `customer`.`mobile` = `invoice`.`customer_mobile` 
INNER JOIN `invoice_item` ON `invoice_item`.`invoice_id` = `invoice`.`invoice_id` 
INNER JOIN `stock` ON `stock`.`id` = `invoice_item`.`stock_id` 
INNER JOIN `product` ON `product`.`intid` = `stock`.`product_intid` 
INNER JOIN `brand` ON `brand`.`id` = `product`.`brand_id` 
INNER JOIN `sub_category` ON `sub_category`.`id` = `product`.`sub_category_id`
INNER JOIN `category` ON `category`.`id` = `sub_category`.`category_id` 
INNER JOIN `location` ON `location`.`id` = `stock`.`location_id` 
INNER JOIN `job_warrenty` ON `invoice`.`job_warrenty_warrenty_id` = `job_warrenty`.`warrenty_id`
INNER JOIN `payment_method` ON `payment_method`.`Payment_id` = `invoice`.`payment_method_Payment_id` 
WHERE `invoice`.`invoice_id` = $P{id} 
]]></query>
