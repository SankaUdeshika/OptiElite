	<query language="SQL"><![CDATA[SELECT `R_Axis`,`L_Axis`,`R_CYL`,`L_CYL`,`job_no`,`users_id`,`prescripiton_date`,`L_distance`,`L_Addition`,`L_N_PD`,`L_M_PD`,`L_CYL`,`L_Va`,`L_Axis`,`R_Va`,`R_N_PD`,`R_M_PD`,`R_distance`,`R_Addition`,`R_CYL`,`R_Axis`,`customer_mobile`,`fname`,`lname`,`locaiton_mobile`,`location_name`,`branch_name`,`branch_address`,`mobile`,`address_line1`,`address_line2`,`mobile2`,`telephone_land`,`nic`,`name` FROM `prescription_details` INNER JOIN `users` ON `users`.`id` = `prescription_details`.`users_id` INNER JOIN `location` ON `location`.`id` = `users`.`location_id` INNER JOIN `customer` ON `customer`.`mobile` = `prescription_details`.`customer_mobile`   WHERE `job_no` =  $P{jobno}  ]]></query>
