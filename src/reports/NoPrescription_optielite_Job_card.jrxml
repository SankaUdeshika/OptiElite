<jasperReport name="NoPrescription_optielite_Job_card" language="java" columnCount="1" pageWidth="420" pageHeight="595" orientation="Landscape" columnWidth="380" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="68c75e0e-555c-4fb6-b074-4ee0e6cad33a">
