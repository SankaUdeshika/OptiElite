	<query language="sql"><![CDATA[SELECT
`branch_address`,
	`company_email`,
	`web`,
	`reg_no`,
	`reg_name`,
	`lens_id`,
	`L_HEIGHT`,
	`R_HEIGHT`,
	`lens_Qty`,
	`lens_price`,
	`lens_code`,
	`delivery_date`,
	`delivery_time`,
	`fname`,
	`lname`,
	`R_Axis`,
	`L_Axis`,
	`R_CYL`,
	`L_CYL`,
	prescription_details.job_no,
	prescription_details.users_id,
	`prescripiton_date`,
	`L_SPH`,
	`L_Addition`,
	`L_NVA`,
	`L_M_PD`,
	`L_CYL`,
	`L_DVA`,
	`L_Axis`,
	`R_DVA`,
	`R_NVA`,
	`R_M_PD`,
	`R_SPH`,
	`R_Addition`,
	`R_CYL`,
	`R_Axis`,
	`location_mobile2`,
	`warrenty`,
	product.id,
	`lenstotal`,
	`advance_payment`,
	invoice.prescription_details_job_no,
	`branch_address`,
	`locaiton_mobile`,
	`branch_name`,
	`payment_name`,
	`saling_price`,
	`location_name`,
	invoice_item.qty,
	`Category`,
	`sub_category`,
	`brand_name`,
	`product_name`,
	invoice.invoice_id,
	`date`,
	`total_price`,
	`discount`,
	`subtotal`,
	`address_line1`,
	`address_line2`,
	customer.mobile,
	`mobile2`,
	`telephone_land`,
	`nic`,
	`name`
FROM invoice
	INNER JOIN customer ON 
	 customer.mobile = invoice.customer_mobile 
	INNER JOIN invoice_item ON 
	 invoice_item.invoice_id = invoice.invoice_id 
	INNER JOIN stock ON 
	 stock.id = invoice_item.stock_id 
	INNER JOIN product ON 
	 product.intid = stock.product_intid 
	INNER JOIN brand ON 
	 brand.id = product.brand_id 
	INNER JOIN sub_category ON 
	 sub_category.id = product.sub_category_id 
	INNER JOIN category ON 
	 category.id = sub_category.category_id 
	INNER JOIN location ON 
	 location.id = invoice_location
	INNER JOIN job_warrenty ON 
	 invoice.job_warrenty_warrenty_id = job_warrenty.warrenty_id 
	INNER JOIN payment_method ON 
	 payment_method.`Payment_id` = invoice.`payment_method_Payment_id` 
	INNER JOIN prescription_details ON 
	 prescription_details.job_no = invoice.prescription_details_job_no 
	INNER JOIN users ON 
	users.id = prescription_details.users_id 
	INNER JOIN lens_stock ON
	 invoice.`lens_stock_lens_id` = lens_stock.`lens_id`
WHERE 
	 invoice.invoice_id = $P{id}]]></query>
