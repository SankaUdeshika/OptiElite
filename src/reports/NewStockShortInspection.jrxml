<!-- Created with Jaspersoft Studio version 7.0.0.final using JasperReports Library version 7.0.0-b478feaa9aab4375eba71de77b4ca138ad2f62aa  -->
<jasperReport name="NewStockShortInspection" language="java" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="bb97e804-b186-4bbd-8d62-0eddf5d76cc6">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Optielite.jrdax"/>
	<parameter name="location_id" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT 
    b.brand_name,
    p.id AS product_id,
    p.product_name,
    p.description AS product_description,
    sc.sub_category,
    c.Category,
    q.Quality_Name,
    s.color,
    s.frameSize,
    s.SKU,
    s.saling_price,
    s.cost,
    s.location_id,
    SUM(s.qty) AS total_qty
FROM stock s
JOIN product p ON s.product_intid = p.intid AND s.product_id = p.id
JOIN brand b ON p.brand_id = b.id
JOIN sub_category sc ON p.sub_category_id = sc.id
JOIN category c ON sc.category_id = c.id
JOIN quality q ON p.Quality_id = q.id
WHERE 
    s.location_id =   $P{location_id}         -- Replace ? with your target location ID
GROUP BY 
    b.brand_name,
    p.id,
    p.product_name,
    p.description,
    sc.sub_category,
    c.Category,
    q.Quality_Name,
    s.color,
    s.frameSize,
    s.SKU,
    s.saling_price,            -- Separate rows for different selling prices
    s.cost,
    s.location_id
HAVING 
    SUM(s.qty) >= 1
ORDER BY 
    b.brand_name ASC,
    p.id ASC;]]></query>
