	<query language="SQL"><![CDATA[SELECT 
	branch_name,
	fname,
	time,
	lname,
	daily_report.report_id,
	date,
	location_name,
	daily_report.location_id 
FROM daily_report
	INNER JOIN location ON 
	 location.id = daily_report.location_id 
	INNER JOIN users ON 
	 users.id = daily_report.users_id
	 
	 WHERE `daily_report`.`report_id` =  $P{id} ]]></query>
