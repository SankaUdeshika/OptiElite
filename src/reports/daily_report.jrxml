	<dataset name="Empty Dataset1" uuid="ae0fdeeb-a58d-4ecd-90a3-43a7262fe1bf">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Optielite.jrdax"/>
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<query language="SQL"><![CDATA[SELECT  `invoice_id`,`name`,`payment_name`
 FROM `advance_payment_history`
 INNER JOIN `invoice` ON `invoice`.`invoice_id` = `advance_payment_history`.`invoice_invoice_id`
INNER JOIN `payment_method` ON `payment_method`.`Payment_id` = `invoice`.payment_method_Payment_id
INNER JOIN `customer` ON `customer`.`mobile` = `invoice`.customer_mobile]]></query>
		<field name="invoice_id" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.name" value="invoice_id"/>
			<property name="com.jaspersoft.studio.field.label" value="invoice_id"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="invoice"/>
		</field>
		<field name="name" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="name"/>
			<property name="com.jaspersoft.studio.field.label" value="name"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="customer"/>
		</field>
		<field name="payment_name" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="payment_name"/>
			<property name="com.jaspersoft.studio.field.label" value="payment_name"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="payment_method"/>
		</field>
	</dataset>
	<dataset name="daily_payment" uuid="3379ab28-afb5-440a-bb78-9a42d7120e3c">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Optielite.jrdax"/>
		<parameter name="today_date" class="java.lang.String">
			<defaultValueExpression><![CDATA[new java.text.SimpleDateFormat("yyyy-MM-dd").format(new java.util.Date())]]></defaultValueExpression>
		</parameter>
		<parameter name="location_detail" class="java.lang.String"/>
		<query language="SQL"><![CDATA[SELECT invoice.invoice_id,
	`name`,
	`payment_name`,
	`payment_method`,
	`paid_amount`
FROM advance_payment_history
	INNER JOIN invoice ON 
	 invoice.invoice_id = advance_payment_history.invoice_invoice_id 
	INNER JOIN payment_method ON 
	 payment_method.`Payment_id` = invoice.`payment_method_Payment_id` 
	INNER JOIN customer ON 
	 customer.mobile = invoice.customer_mobile 
	 WHERE 
	 advance_payment_history.date = $P{today_date}
	 AND advance_payment_history.location_id = $P{location_detail} 

]]></query>
		<field name="invoice_id" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="invoice_id"/>
			<property name="com.jaspersoft.studio.field.label" value="invoice_id"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="invoice"/>
		</field>
		<field name="name" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="name"/>
			<property name="com.jaspersoft.studio.field.label" value="name"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="customer"/>
		</field>
		<field name="payment_name" class="java.lang.String">
