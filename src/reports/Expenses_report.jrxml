	<parameter name="report_item_id" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT 
	report_item_id,
	description,
	amount,
	date,
	time,
	location_id,
	users_id,
	reg_no,
	company_email,
	web,
	branch_address,
	reg_name
FROM report_item
	INNER JOIN daily_report ON 
	 daily_report.report_id = report_item.daily_report_report_id
	 	INNER JOIN location ON 
	 location.id = daily_report.location_id
	 WHERE report_item.report_item_id =  $P{report_item_id} ]]></query>
